@inherits LayoutComponentBase
@inject AuthService Auth
@inject TokenStore Store
@inject NavigationManager Nav

<MudLayout Class="app-shell">
    <MudDrawer @bind-Open="_drawerOpen"
               Breakpoint="Breakpoint.Md"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Never"
               Elevation="0"
               Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudAppBar Elevation="0" Color="Color.Default" Class="app-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Primary"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       Class="me-2" />
        <MudText Typo="Typo.h6" Class="app-bar-title">Sponsorship Workflow</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <div class="user-strip">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">@Initials</MudAvatar>
                    <div class="user-copy">
                        <MudText Typo="Typo.body2" Class="fw-semibold">@Store.FullName</MudText>
                        <MudText Typo="Typo.caption">@UserSubline</MudText>
                    </div>
                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">@Store.Role</MudChip>
                </div>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Logout"
                           OnClick="Logout">
                    Logout
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Login">
                    Login
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent Class="main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="content-wrap">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _restored;

    private string UserSubline => string.IsNullOrWhiteSpace(Store.Department) ? Store.Email ?? "" : Store.Department!;

    private string Initials
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Store.FullName))
            {
                return "SW";
            }

            var parts = Store.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_restored)
        {
            _restored = true;
            if (!Store.IsAuthenticated)
            {
                await Auth.TryRestoreAsync();
                StateHasChanged();
            }
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
