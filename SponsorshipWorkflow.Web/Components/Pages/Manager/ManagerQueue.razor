@page "/manager/queue"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Manager,SystemAdmin")]
@inject ApiClient Api

<PageTitle>Manager Queue</PageTitle>

<div class="page-heading">
    <div>
        <h1>Pending Manager Approvals</h1>
        <p>Review submitted requests waiting for manager decision.</p>
    </div>
    @if (_items is not null)
    {
        <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">@_items.Count pending</MudChip>
    }
</div>

@if (_loading) { <MudProgressLinear Color="Color.Primary" Indeterminate="true" /> }
else if (_items == null || _items.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No pending approvals.</MudAlert> }
else
{
    <MudPaper Class="pa-4 rich-panel" Elevation="0">
        <MudTable Items="_items" Hover="true" Dense="true" Elevation="0" Class="rich-table">
            <HeaderContent>
                <MudTh>Number</MudTh>
                <MudTh>Title</MudTh>
                <MudTh>Requestor</MudTh>
                <MudTh>Department</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Submitted</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Number">@context.RequestNumber</MudTd>
                <MudTd DataLabel="Title">@context.Title</MudTd>
                <MudTd DataLabel="Requestor">@context.RequestorName</MudTd>
                <MudTd DataLabel="Department">@context.Department</MudTd>
                <MudTd DataLabel="Type">@context.SponsorshipTypeName</MudTd>
                <MudTd DataLabel="Amount">@context.RequestedAmount.ToString("N2")</MudTd>
                <MudTd DataLabel="Submitted">@(context.SubmittedAt?.ToLocalTime().ToString("g") ?? "-")</MudTd>
                <MudTd DataLabel="Actions" Class="text-end">
                    <MudButton Href="@($"requests/{context.Id}")" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.ArrowForward">Review</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<SponsorshipRequestSummaryDto>? _items;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var res = await Api.GetAsync<List<SponsorshipRequestSummaryDto>>("/api/SponsorshipRequests/pending-manager-approval");
        _items = res?.Data ?? new();
        _loading = false;
    }
}
