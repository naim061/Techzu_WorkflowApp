@page "/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "SystemAdmin")]
@inject ApiClient Api

<PageTitle>Pending Users</PageTitle>

<div class="page-heading">
    <div>
        <h1>Pending Users</h1>
        <p>Approve registered users so they can submit sponsorship requests.</p>
    </div>
    @if (_items is not null)
    {
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@_items.Count pending</MudChip>
    }
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@_error</MudAlert>
}
else if (_items == null || _items.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No pending users.</MudAlert>
}
else
{
    <MudPaper Class="pa-4 rich-panel" Elevation="0">
        <MudTable Items="_items" Hover="true" Dense="true" Elevation="0" Class="rich-table">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Department</MudTh>
                <MudTh>Registered</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.FullName</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Department">@(context.Department ?? "-")</MudTd>
                <MudTd DataLabel="Registered">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                <MudTd DataLabel="Actions" Class="text-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="@_approving.Contains(context.Id)"
                               OnClick="@(() => Approve(context.Id))"
                               StartIcon="@Icons.Material.Filled.CheckCircle">
                        Approve
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<UserDto>? _items;
    private readonly HashSet<Guid> _approving = new();
    private string? _error;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            var res = await Api.GetAsync<List<UserDto>>("/api/Auth/pending-users");
            if (res?.Success == true)
            {
                _items = res.Data ?? new();
            }
            else
            {
                _items = new();
                _error = res?.Message ?? "Unable to load pending users.";
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Approve(Guid userId)
    {
        _error = null;
        _approving.Add(userId);
        try
        {
            var res = await Api.PostAsync<UserDto>($"/api/Auth/users/{userId}/approve", null);
            if (res?.Success == true)
            {
                _items?.RemoveAll(u => u.Id == userId);
            }
            else
            {
                _error = res?.Message ?? "Unable to approve user.";
            }
        }
        finally
        {
            _approving.Remove(userId);
        }
    }
}