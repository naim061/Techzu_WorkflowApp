<div class="workflow-progress">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <MudText Typo="Typo.caption" Class="text-muted">@Label</MudText>
        <MudText Typo="Typo.caption" Class="fw-semibold">@Progress%</MudText>
    </div>
    <MudProgressLinear Color="@BarColor" Value="@Progress" Rounded="true" />
</div>

@code {
    [Parameter] public string Status { get; set; } = "";

    private int Progress => Status switch
    {
        "Draft" => 15,
        "PendingManagerApproval" => 40,
        "PendingFinanceReview" => 70,
        "Approved" => 100,
        "Rejected" or "Cancelled" => 100,
        _ => 10
    };

    private Color BarColor => Status switch
    {
        "Approved" => Color.Success,
        "Rejected" or "Cancelled" => Color.Error,
        "PendingManagerApproval" => Color.Warning,
        "PendingFinanceReview" => Color.Info,
        _ => Color.Primary
    };

    private string Label => Status switch
    {
        "Draft" => "Draft preparation",
        "PendingManagerApproval" => "Manager approval",
        "PendingFinanceReview" => "Finance review",
        "Approved" => "Approved workflow",
        "Rejected" => "Rejected workflow",
        "Cancelled" => "Cancelled workflow",
        _ => "Workflow progress"
    };
}
